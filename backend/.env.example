# ── Application ──────────────────────────────────────────────
APP_ENV=development           # development | production
APP_NAME=MeetingMind AI
APP_VERSION=1.0.0
SECRET_KEY=change-me-to-a-long-random-secret-key-in-production
DEBUG=true
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# ── Database ─────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/meetingmind
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# ── Redis / Celery ───────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ── JWT ──────────────────────────────────────────────────────
JWT_SECRET=another-long-secret-for-jwt-signing
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# ── AI / LLM ─────────────────────────────────────────────────
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxx   # fallback
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_FALLBACK_MODEL=deepseek-r1-distill-llama-70b
WHISPER_MODEL_SIZE=large-v3                       # tiny|base|small|medium|large-v3
WHISPER_DEVICE=cpu                                # cpu | cuda
WHISPER_COMPUTE_TYPE=int8                         # int8 | float16 | float32

# ── Vector DB ────────────────────────────────────────────────
CHROMA_DB_PATH=./data/chromadb
CHROMA_COLLECTION_TRANSCRIPTS=meeting_transcripts
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ── Storage ──────────────────────────────────────────────────
STORAGE_BACKEND=local                             # local | s3 | r2
LOCAL_STORAGE_PATH=./data/uploads

AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY
AWS_BUCKET_NAME=meetingmind-uploads
AWS_REGION=ap-south-1

# Cloudflare R2 (uses S3-compatible API)
R2_ENDPOINT_URL=https://ACCOUNT_ID.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=meetingmind-uploads

# ── Rate Limiting ────────────────────────────────────────────
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60          # seconds

# ── File Upload ──────────────────────────────────────────────
MAX_UPLOAD_SIZE_MB=2048
ALLOWED_AUDIO_FORMATS=mp3,wav,m4a,ogg,flac
ALLOWED_VIDEO_FORMATS=mp4,mkv,mov,avi,webm

# ── Zoom (Phase 4) ───────────────────────────────────────────
ZOOM_CLIENT_ID=
ZOOM_CLIENT_SECRET=
ZOOM_WEBHOOK_SECRET=

# ── Google (Phase 4) ─────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Phase 2: Speaker Diarization ─────────────────────────────
# 1. Create account at huggingface.co
# 2. Accept license at huggingface.co/pyannote/speaker-diarization-3.1
# 3. Accept license at huggingface.co/pyannote/segmentation-3.0
# 4. Create token at huggingface.co/settings/tokens
HUGGINGFACE_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
DIARIZATION_ENABLED=true

# ── Phase 3: Face Recognition ────────────────────────────────
# InsightFace buffalo_l model is downloaded automatically on first use.
# For GPU acceleration:
#   1. Install CUDA toolkit
#   2. Replace onnxruntime with onnxruntime-gpu in requirements-phase3.txt
FACE_RECOGNITION_ENABLED=true
FACE_MATCH_THRESHOLD=0.45          # 0.0-1.0; higher = stricter matching
FACE_FRAME_INTERVAL_SEC=5.0        # extract 1 frame every N seconds
FACE_MAX_FRAMES=200                # max frames to process per video

# ── Phase 4: Zoom Bot ─────────────────────────────────────────
# Register at marketplace.zoom.us → Server-to-Server OAuth app
ZOOM_CLIENT_ID=your_zoom_client_id
ZOOM_CLIENT_SECRET=your_zoom_client_secret
ZOOM_ACCOUNT_ID=your_zoom_account_id
ZOOM_WEBHOOK_SECRET=your_zoom_webhook_secret

# ── Phase 4: Google Meet Bot ──────────────────────────────────
# No credentials needed for public meetings (guest join)
# For private meetings, add Google OAuth credentials:
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# ── Phase 4: WebSocket ────────────────────────────────────────
# No extra config needed — WS endpoint is at /ws/transcribe
# Clients connect with: ?meeting_id=<uuid>&token=<jwt>
